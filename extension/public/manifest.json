{
    "manifest_version": 3,
    "name": "Aegis Password Manager",
    "description": "Password Manager extension for your Aegis vault.",
    "version": "1.0.0",

    "action": {},

    "background": {
        "service_worker": "background.js"
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": [
                "content/autofill.js",
                "content/popup-injector.js"
            ]
        }
    ],

    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],

    "host_permissions": [
        "<all_urls>"
    ],

    "web_accessible_resources": [
        {
            "resources": ["assets/*", "index.html"],
            "matches": ["<all_urls>"]
        }
    ],

    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self';"
    },

    "icons": {
        "16": "assets/icon16.png",
        "32": "assets/icon32.png",
        "48": "assets/icon48.png",
        "128": "assets/icon128.png"
    }
}
